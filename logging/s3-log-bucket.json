{
  "bucket_name": "org-log-archive-bucket",
  "versioning": {
    "enabled": true
  },
  "encryption": {
    "type": "SSE-S3"
  },
  "public_access_block": {
    "block_public_acls": true,
    "block_public_policy": true,
    "ignore_public_acls": true,
    "restrict_public_buckets": true
  },
  "object_lock": {
    "enabled": true
  }
}